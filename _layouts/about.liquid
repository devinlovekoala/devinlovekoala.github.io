---
layout: default
---
<div class="about-page">
  <!-- Left sidebar -->
  <aside class="about-sidebar">
    {% if page.profile and page.profile.image %}
      {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
      <div class="about-avatar-wrap">
        {%
          include figure.liquid loading="eager" path=profile_image_path
          class="about-avatar" alt="profile photo" cache_bust=true
        %}
      </div>
    {% endif %}

    <h1 class="about-name">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span>{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>

    <p class="about-role">Undergraduate</p>
    <p class="about-org"><a href="https://www.bupt.edu.cn/">BUPT</a></p>

    <div class="about-social-links">
      {% if site.data.socials.scholar_userid %}
        <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank" rel="noopener">
          <i class="ai ai-google-scholar"></i> Google Scholar
        </a>
      {% endif %}
      {% if site.data.socials.github_username %}
        <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" rel="noopener">
          <i class="fa-brands fa-github"></i> GitHub
        </a>
      {% endif %}
      {% if site.data.socials.linkedin_username %}
        <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" rel="noopener">
          <i class="fa-brands fa-linkedin"></i> LinkedIn
        </a>
      {% endif %}
      {% if site.data.socials.twitter_username %}
        <a href="https://twitter.com/{{ site.data.socials.twitter_username }}" target="_blank" rel="noopener">
          <i class="fa-brands fa-x-twitter"></i> Twitter
        </a>
      {% endif %}
      {% if site.data.socials.email %}
        <a href="mailto:{{ site.data.socials.email }}">
          <i class="fa-solid fa-envelope"></i> Email
        </a>
      {% endif %}
      {% if site.data.socials.cv_pdf %}
        <a href="{{ site.data.socials.cv_pdf | relative_url }}">
          <i class="fa-solid fa-file-pdf"></i> CV
        </a>
      {% endif %}
    </div>
  </aside>

  <!-- Right content -->
  <main class="about-content">
    <h2 class="about-section-title">About Me</h2>
    <div class="about-bio">{{ content }}</div>

    {% if page.announcements and page.announcements.enabled %}
      <h2 class="about-section-title">
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    {% if page.selected_papers %}
      <h2 class="about-section-title">
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </main>
</div>
